# Database Configuration (Supabase)
SPRING_DATASOURCE_URL=jdbc:postgresql://db.[project-id].supabase.co:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_supabase_password

# Authentication Configuration (Keycloak)
KEYCLOAK_ISSUER_URI=https://[keycloak-domain]/realms/kubiku
KEYCLOAK_JWK_SET_URI=https://[keycloak-domain]/realms/kubiku/protocol/openid-connect/certs

# Spring Profile
SPRING_PROFILES_ACTIVE=prod
