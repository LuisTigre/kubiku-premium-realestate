{
  "id": "kubiku",
  "realm": "kubiku",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "verifyEmail": false,
  "resetPasswordAllowed": true,
  "internationalizationEnabled": true,
  "supportedLocales": [
    "en",
    "pt-BR"
  ],
  "defaultLocale": "",
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Standard app user"
      },
      {
        "name": "PARTNER",
        "description": "Hospitality or Real Estate partner"
      },
      {
        "name": "ADMIN",
        "description": "Platform administrator"
      }
    ]
  },
  "clients": [
    {
      "clientId": "kubiku-web",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "publicClient": true,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      }
    },
    {
      "clientId": "kubiku-api",
      "enabled": true,
      "bearerOnly": false,
      "publicClient": false,
      "secret": "kubiku-api-secret",
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "email": "testuser@kubiku.com",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "testpassword",
          "temporary": false
        }
      ],
      "realmRoles": [
        "USER"
      ]
    }
  ]
}