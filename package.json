{
  "name": "kubiku-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "web:dev": "npm run dev --workspace=web",
    "web:build": "npm run build --workspace=web",
    "api:dev": "cd apps/api && ./mvnw spring-boot:run",
    "api:build": "cd apps/api && ./mvnw clean install",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  }
}
